# Copy this file to .env before using docker compose.
# Never commit your real .env file.

# Required for the Discord bot.
DISCORD_TOKEN=replace-with-discord-bot-token

# Dashboard/admin security.
SDAC_ADMIN_KEY=replace-with-long-random-admin-key
SDAC_SECRET_KEY=replace-with-long-random-session-secret

# Public dashboard URL used in Discord links and OAuth callbacks.
SDAC_PUBLIC_URL=http://localhost:5000
SANA_DASHBOARD_URL=http://localhost:5000

# Discord OAuth login for dashboard/app.
SDAC_DISCORD_CLIENT_ID=
SDAC_DISCORD_CLIENT_SECRET=
SDAC_BOT_CLIENT_ID=

# Local dashboard port.
SANA_DASHBOARD_PORT=5000

# Upload limits.
SDAC_DASHBOARD_MAX_CONTENT_MB=250

# Optional release/update metadata.
SDAC_RELEASE=development
SDAC_RELEASE_TAG=latest-experimental

# Optional PostgreSQL mode.
# Start with: docker compose --profile postgres up -d
# Then set:
# SDAC_DATABASE_URL=postgresql://sana:change-me@postgres:5432/sana
POSTGRES_DB=sana
POSTGRES_USER=sana
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432
